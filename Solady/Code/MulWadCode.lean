import sys

h = sys.stdin.read().strip()
h = h[2:] if h.startswith("0x") else h
b = bytes.fromhex(h)

per_line = 16

print("ByteArray.mk #[")
for i in range(0, len(b), per_line):
    chunk = b[i:i+per_line]
    line = ", ".join(f"0x{x:02x}" for x in chunk)
    if i + per_line < len(b):
        print("  " + line + ",")
    else:
        print("  " + line)
print("]")
'
